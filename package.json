{
    "name": "ai-live2d",
    "version": "1.0.0",
    "description": "AI-powered Live2D desktop pet",
    "main": "src/main/index.js",
    "scripts": {
        "start": "electron .",
        "dev": "electron . --dev",
        "build": "electron-builder --mac dmg"
    },
    "dependencies": {
        "@huggingface/transformers": "^3.8.1",
        "@xenova/transformers": "^2.17.2",
        "openai": "^4.28.0",
        "pixi-live2d-display": "^0.4.0",
        "pixi.js": "^6.5.10",
        "vectra": "^0.12.3"
    },
    "devDependencies": {
        "electron": "^28.0.0",
        "electron-builder": "^26.8.1"
    },
    "build": {
        "appId": "com.ailive2d.app",
        "productName": "AI Live2D",
        "icon": "build/icon.png",
        "files": [
            "src/**/*",
            "node_modules/**/*",
            "package.json"
        ],
        "extraResources": [
            {
                "from": "config",
                "to": "config",
                "filter": ["**/*"]
            },
            {
                "from": "models",
                "to": "models",
                "filter": ["**/*"]
            },
            {
                "from": "model-cache",
                "to": "model-cache",
                "filter": ["**/*"]
            }
        ],
        "mac": {
            "category": "public.app-category.entertainment",
            "icon": "build/icon.png",
            "target": [
                {
                    "target": "dmg",
                    "arch": [
                        "arm64",
                        "x64"
                    ]
                }
            ]
        },
        "dmg": {
            "title": "AI Live2D",
            "icon": "build/icon.png"
        }
    }
}
